{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"useTabs": true,
	"tabWidth": 2,
	"printWidth": 90,
	"singleQuote": true,
	"jsxSingleQuote": true,
	"quoteProps": "as-needed",
	"trailingComma": "all",
	"semi": true,
	"arrowParens": "always",
	"bracketSameLine": false,
	"bracketSpacing": true,
	"singleAttributePerLine": false,
	"ignorePatterns": [
		"node_modules",
		".next",
		"out",
		"dist",
		"build",
		".wrangler",
		"cloudflare-env.d.ts",
		"next-env.d.ts"
	]
}
